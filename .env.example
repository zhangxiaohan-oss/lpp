# Oufan third-party auth and customer service integration

# Public site URL used in OAuth dashboards, for example:
# https://your-domain.com
NEXT_PUBLIC_SITE_URL=

# Google / Gmail Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Meta / Facebook Login
META_APP_ID=
META_APP_SECRET=
META_API_VERSION=v23.0

# WhatsApp Business Cloud API
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_DISPLAY_NUMBER=
WHATSAPP_VERIFY_TOKEN=

# Messenger / Facebook Page Inbox
FACEBOOK_PAGE_ID=
MESSENGER_PAGE_ACCESS_TOKEN=
MESSENGER_VERIFY_TOKEN=

# Optional production mail support
SUPPORT_EMAIL=hello@lppbeach.com
